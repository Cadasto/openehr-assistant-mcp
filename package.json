{
  "name": "@cadasto/openehr-assistant-mcp",
  "version": "0.14.0",
  "description": "A Model Context Protocol (MCP) Server to assist end-user on various openEHR related tasks and APIs.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Sebastian Iancu",
    "email": "sebastian-iancu@users.noreply.github.com"
  },
  "main": "dist/index.js",
  "bin": {
    "openehr-assistant-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --transport=stdio",
    "dev": "tsx src/index.ts",
    "dev:stdio": "tsx src/index.ts --transport=stdio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.9.0",
    "express": "^4.21.0",
    "fast-xml-parser": "^5.0.0",
    "winston": "^3.17.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
