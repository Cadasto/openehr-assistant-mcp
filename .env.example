# Main Configuration
APP_ENV=production
LOG_LEVEL=info

# CKM API Configuration
CKM_API_BASE_URL=https://ckm.openehr.org/ckm/rest

# Optional: Custom HTTP client settings
HTTP_TIMEOUT=3.0
HTTP_SSL_VERIFY=true

# streamable-http transport DNS-rebinding allow-list (SDK >= 0.6). Comma-separated
# hostnames; defaults to loopback only. Set to your reverse-proxy host / public domain
# when deployed behind a proxy, e.g.:
# MCP_ALLOWED_HOSTS=localhost,127.0.0.1,[::1],openehr-assistant-mcp.apps.cadasto.com
