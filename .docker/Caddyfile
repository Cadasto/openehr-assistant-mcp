{
    # https://caddyserver.com/docs/caddyfile/options#log
    log {
        level INFO
        output stdout
        format console
    }

    # https://caddyserver.com/docs/caddyfile/options#admin
    admin off
    persist_config off

    # https://caddyserver.com/docs/caddyfile/patterns#caddy-proxying-to-another-caddy
    servers {
        trusted_proxies static private_ranges
    }
}

(server_conf) {
    # 1. Block crawlers and robots
    respond /robots.txt "User-agent: *\nDisallow: /"

    # 2. Return an early 204 No Content for favicon images
    @ignored_files {
        path /favicon.ico
    }
    error @ignored_files 204

    # 3. Proxy all requests to the Node.js MCP server (port 3000)
    reverse_proxy app:3000 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}

# HTTPS server with internal certificates
{$HOSTNAME} {
    import server_conf

    tls {
        protocols tls1.3
    }
}

# HTTP development server (no TLS)
:8343 {
    import server_conf
}
